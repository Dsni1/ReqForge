<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ReqForge.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="650"
             x:Class="ReqForge.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#111922"/>
      <Setter Property="BorderBrush" Value="#2A3A4F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="10"/>
    </Style>

    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style Selector="TextBox.editor">
      <Setter Property="FontFamily" Value="Monospace"/>
      <Setter Property="Padding" Value="10"/>
    </Style>

    <Style Selector="TextBox.urlInput">
      <Setter Property="MinWidth" Value="420"/>
      <Setter Property="Padding" Value="10,8"/>
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="ListBox.historyList">
      <Setter Property="MinHeight" Value="220"/>
    </Style>
  </UserControl.Styles>

  <Grid Margin="12" ColumnDefinitions="320,*" ColumnSpacing="12">

    <!-- Left: history panel with fixed column width so content never pushes request controls. -->
    <Border Grid.Column="0" Classes="panel">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Classes="sectionTitle" Text="History"/>

        <ListBox Classes="historyList"
                 ItemsSource="{Binding History}"
                 SelectedItem="{Binding SelectedHistoryItem}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,2,0,6">
                <TextBlock Text="{Binding Url}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Method}" Opacity="0.7" FontSize="11"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Right: request toolbar + request/response editors. -->
    <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="10">
      <Border Grid.Row="0" Classes="panel">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
          <ComboBox Grid.Column="0"
                    Width="110"
                    ItemsSource="{Binding Methods}"
                    SelectedItem="{Binding SelectedMethod}"/>

          <TextBox Grid.Column="1"
                   Classes="urlInput"
                   Text="{Binding Url}"
                   Watermark="https://api.example.com/endpoint"/>

          <Button Grid.Column="2"
                  Classes="primary"
                  Content="Send"
                  Command="{Binding SendRequestCommand}"
                  IsEnabled="{Binding !IsLoading}"/>
        </Grid>
      </Border>

      <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
        <Border Grid.Column="0" Classes="panel">
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,8">
              <TextBlock Classes="sectionTitle" Text="Request Headers" Margin="0"/>
              <TextBox Classes="editor"
                       AcceptsReturn="True"
                       Text="{Binding RequestHeader}"
                       Height="120"
                       Watermark="Authorization: Bearer eyJ...&#10;Content-Type: application/json"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Top" Classes="sectionTitle" Text="Request Body"/>
            <TextBox Classes="editor"
                     AcceptsReturn="True"
                     Text="{Binding RequestBody}"
                     VerticalAlignment="Stretch"/>
          </DockPanel>
        </Border>

        <Border Grid.Column="1" Classes="panel">
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
              <TextBlock Text="Response" FontWeight="Bold"/>
              <TextBlock Text="{Binding StatusCode}" Foreground="#87D37C"/>
              <TextBlock Text="{Binding ElapsedTime, StringFormat='{}{0:F0} ms'}" Foreground="#A4B0BE"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}" Foreground="#FF6B6B"/>

            <ScrollViewer>
              <TextBox Classes="editor"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       Text="{Binding ResponseBody}"/>
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
